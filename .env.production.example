# CACMS Production Environment — AWS EC2 + RDS
# Copy to .env.production on your EC2 instance and fill in all values.
# NEVER commit this file with real values to git.

# --- Runtime ---
ENVIRONMENT=production

# --- Database (AWS RDS PostgreSQL) ---
# Format: postgresql+asyncpg://USER:PASSWORD@RDS_ENDPOINT:5432/DATABASE
DATABASE_URL=postgresql+asyncpg://cacms_user:CHANGE_ME@YOUR_RDS_ENDPOINT.rds.amazonaws.com:5432/cacms

# --- Auth ---
# Generate: python3 -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET=GENERATE_64_CHAR_HEX_HERE
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=60

# --- CORS ---
# Your EC2 public IP (no domain yet):
CORS_ORIGINS=http://YOUR_EC2_PUBLIC_IP:8000
# With a domain + HTTPS (preferred):
# CORS_ORIGINS=https://yourdomain.com

# --- OTP ---
OTP_TTL_SECONDS=300

# --- Rate limiting ---
AUTH_RATE_LIMIT=10/minute

# --- Backups ---
# Generate: python3 -c "import secrets; print(secrets.token_hex(32))"
BACKUP_ENCRYPTION_KEY=GENERATE_64_CHAR_HEX_HERE
BACKUP_DIR=/var/backups/cacms

# --- Redis (sidecar on EC2 — do not change) ---
REDIS_URL=redis://redis:6379/0

# --- Monitoring (optional but recommended) ---
SENTRY_DSN=
SENTRY_TRACES_SAMPLE_RATE=0.1

# --- Super-admin (static token, not JWT) ---
# Required in production; generate with:
#   python3 -c "import secrets; print(secrets.token_hex(32))"
SUPERADMIN_TOKEN=GENERATE_64_CHAR_HEX_HERE
