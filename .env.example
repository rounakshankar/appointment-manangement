# CACMS — copy to `.env` and adjust. See CACMS_Platform_Strategy doc Appendix for future vars.

# --- Core ---
ENVIRONMENT=development
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/cacms
REDIS_URL=redis://localhost:6379/0

# --- Docker “public” compose (docker-compose.public.yml) ---
# Postgres on THIS machine while API runs in Docker: use host.docker.internal, not localhost.
# Example (adjust user, password, database):
# DATABASE_URL=postgresql+asyncpg://postgres:YOUR_PASSWORD@host.docker.internal:5432/cacms_test
# JWT_SECRET=...   # required; generate a long random string
# Optional: add your LAN/public origins if you call the API from a web app on another port:
# CORS_ORIGINS=http://localhost:8000,http://127.0.0.1:8000,http://192.168.1.10:8080

# Required: generate with
#   python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET=
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=60

# Comma-separated origins (browsers); empty list logs a warning at startup
# Local dev:
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:8080
# AWS EC2 production (replace with your actual EC2 public IP or domain):
# CORS_ORIGINS=https://yourdomain.com,https://www.yourdomain.com
# If using EC2 public IP directly (no domain yet):
# CORS_ORIGINS=http://YOUR_EC2_PUBLIC_IP:8000

# --- OTP ---
OTP_TTL_SECONDS=300

# --- Rate limiting (slowapi) ---
AUTH_RATE_LIMIT=10/minute

# --- Backups (ops) ---
BACKUP_ENCRYPTION_KEY=
BACKUP_DIR=/var/backups/cacms

# --- Optional: seed_admin.py ---
SEED_ADMIN_USERNAME=
SEED_ADMIN_PASSWORD=

# --- Super-admin (static token, not JWT) ---
# Required in production; generate with:
#   python -c "import secrets; print(secrets.token_hex(32))"
SUPERADMIN_TOKEN=

# --- Monitoring (leave empty to disable) ---
SENTRY_DSN=
# 0.0 = no performance traces; raise in production if you want APM sampling
SENTRY_TRACES_SAMPLE_RATE=0.0

# --- Future: billing (Phase 1+) ---
# (No payment gateway — clinics pay directly via cash/UPI; plans activated via super-admin API)

# --- Email / SMTP (optional; when not configured, emails are logged to console) ---
# EMAIL_FROM=noreply@yourclinic.com
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USERNAME=your@gmail.com
# SMTP_PASSWORD=your_app_password

# --- Future: messaging (Phase 2+) ---
# MSG91_AUTH_KEY=
# MSG91_SENDER_ID=CACMS
# WATI_API_ENDPOINT=https://live-server.wati.io
# WATI_ACCESS_TOKEN=

# --- Future: storage (Phase 2+) ---
