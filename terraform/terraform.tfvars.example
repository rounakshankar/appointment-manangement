# CACMS Terraform variables
# Copy to terraform.tfvars and fill in your values.
# NEVER commit terraform.tfvars to git.

aws_region        = "ap-south-1"
ec2_key_pair_name = "cacms-key"

# Your public IP for SSH access (run: curl ifconfig.me)
# Use 0.0.0.0/0 if on IPv6 or dynamic IP
ssh_allowed_cidr = "0.0.0.0/0"

# RDS password (min 8 chars)
rds_password = "CHANGE_ME_strong_password"

# Generate with: python3 -c "import secrets; print(secrets.token_hex(32))"
jwt_secret            = "GENERATE_64_CHAR_HEX"
superadmin_token      = "GENERATE_64_CHAR_HEX"
backup_encryption_key = "GENERATE_64_CHAR_HEX"

git_repo_url = "https://github.com/rounakshankar/appointment-manangement.git"
git_branch   = "main"

sentry_dsn = ""
